# azapptoolkit build-time configuration.
#
# Copy this file to `.env` at the repo root and fill in the GUIDs from
# your tenant's Entra app registration. When `.env` is present at build
# time, the values are baked into the desktop binary (see
# apps/desktop/src-tauri/build.rs), so the installer you produce does not
# require recipients to set environment variables on their workstations.
#
# Precedence at runtime: a real `AZAPPTOOLKIT_*` env var on the user's
# machine overrides the baked-in value, so individual developers can
# still point a packaged build at a different tenant for testing.

AZAPPTOOLKIT_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZAPPTOOLKIT_TENANT_ID=00000000-0000-0000-0000-000000000000
